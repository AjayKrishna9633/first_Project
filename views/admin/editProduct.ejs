        // Form submission handling with validation
        let isSubmitting = false; // Flag to prevent double submission
        
        function validateEditForm() {
            // Validate product name
            const productNameInput = document.querySelector('input[name="productName"]');
            const productName = productNameInput.value.trim();
            
            if (productName.length < 3) {
                Swal.fire({
                    title: 'Invalid Product Name',
                    text: 'Product name must be at least 3 characters long',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                productNameInput.focus();
                return false;
            }
            
            // Validate description
            const descriptionInput = document.querySelector('textarea[name="description"]');
            const description = descriptionInput.value.trim();
            
            if (description.length < 10) {
                Swal.fire({
                    title: 'Invalid Description',
                    text: 'Description must be at least 10 characters long',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                descriptionInput.focus();
                return false;
            }
            
            // Validate category
            const categoryInput = document.querySelector('select[name="category"]');
            if (!categoryInput.value) {
                Swal.fire({
                    title: 'Category Required',
                    text: 'Please select a category',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                categoryInput.focus();
                return false;
            }
            
            // Validate existing variants
            const existingVariants = document.querySelectorAll('[data-variant-id]');
            for (let variant of existingVariants) {
                const variantId = variant.getAttribute('data-variant-id');
                const variantColor = variant.querySelector('[data-color]').value.trim();
                
                // Validate color
                if (variantColor.length < 2) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `Variant "${variantColor || 'Empty'}": Color must be at least 2 characters`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    variant.querySelector('[data-color]').focus();
                    return false;
                }
                
                // Check for invalid characters (only dashes, underscores, numbers, or special chars)
                if (/^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(variantColor)) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `Variant: "${variantColor}" is not a valid color name. Please enter a proper color with letters (e.g., Black, White, Red)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    variant.querySelector('[data-color]').focus();
                    return false;
                }
                
                // Validate stock quantity
                const quantityInput = variant.querySelector('[data-stock]');
                const quantity = parseInt(quantityInput.value);
                
                if (isNaN(quantity) || quantity < 0) {
                    Swal.fire({
                        title: 'Invalid Stock',
                        text: `Variant "${variantColor}": Stock quantity must be 0 or greater`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    quantityInput.focus();
                    return false;
                }
                
                // Validate prices
                const regularPrice = parseFloat(variant.querySelector('[data-regular]').value) || 0;
                const salePrice = parseFloat(variant.querySelector('[data-sale]').value) || 0;
                
                if (regularPrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant "${variantColor}": Regular price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                if (salePrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant "${variantColor}": Sale price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                // Validate prices first
                if (!validatePrices(variant)) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant "${variantColor}": Sale price cannot exceed regular price`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                // Count existing images
                const currentImagesContainer = document.getElementById(`currentImages_${variantId}`);
                const existingImages = currentImagesContainer ? currentImagesContainer.querySelectorAll('[data-image-url]').length : 0;
                
                // Count new images
                const newImages = croppedFiles[variantId] ? croppedFiles[variantId].length : 0;
                
                const totalImages = existingImages + newImages;
                
                // Minimum 3 images required
                if (totalImages < 3) {
                    Swal.fire({
                        title: 'Insufficient Images',
                        text: `Variant "${variantColor}" requires minimum 3 images! Currently: ${totalImages} image(s)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
            }
            
            // Validate new variants
            const newVariants = document.querySelectorAll('[data-new-variant-index]');
            for (let variant of newVariants) {
                const variantIndex = variant.getAttribute('data-new-variant-index');
                const variantColor = variant.querySelector('[data-color]').value.trim();
                
                // Validate color
                if (variantColor.length < 2) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `New variant: Color must be at least 2 characters`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    variant.querySelector('[data-color]').focus();
                    return false;
                }
                
                // Check for invalid characters
                if (/^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(variantColor)) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `New variant: "${variantColor}" is not a valid color name. Please enter a proper color with letters (e.g., Black, White, Red)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    variant.querySelector('[data-color]').focus();
                    return false;
                }
                
                // Validate stock quantity
                const quantityInput = variant.querySelector('[data-stock]');
                const quantity = parseInt(quantityInput.value);
                
                if (isNaN(quantity) || quantity < 0) {
                    Swal.fire({
                        title: 'Invalid Stock',
                        text: `New variant "${variantColor}": Stock quantity must be 0 or greater`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    quantityInput.focus();
                    return false;
                }
                
                // Validate prices
                const regularPrice = parseFloat(variant.querySelector('[data-regular]').value) || 0;
                const salePrice = parseFloat(variant.querySelector('[data-sale]').value) || 0;
                
                if (regularPrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `New variant "${variantColor}": Regular price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                if (salePrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `New variant "${variantColor}": Sale price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                // Validate prices first
                if (!validatePrices(variant)) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `New variant "${variantColor || 'Unnamed'}": Sale price cannot exceed regular price`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                const images = croppedFiles[variantIndex] ? croppedFiles[variantIndex].length : 0;
                
                // Minimum 3 images required
                if (images < 3) {
                    Swal.fire({
                        title: 'Insufficient Images',
                        text: `New variant "${variantColor || 'Unnamed'}" requires minimum 3 images! Currently: ${images} image(s)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
            }
            
            return true;
        }
        
        function submitEditForm() {
            // Validate before submission
            if (!validateEditForm()) {
                return;
            }
            
            // Prevent double submission
            if (isSubmitting) {
                console.log('Form is already being submitted, ignoring duplicate call');
                return;
            }
            
            isSubmitting = true;
            
            const form = document.querySelector('#editProductForm');
            const formData = new FormData(form);
            const submitBtn = document.getElementById('submitBtn');
            
            // Show loading
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Updating Product...';
            
            // Remove old file inputs
            const oldInputs = form.querySelectorAll('.variant-images-input');
            oldInputs.forEach(input => {
                input.remove();
            });

            // Add cropped images for both new and existing variants
            for (const variantIndex in croppedFiles) {
                const files = croppedFiles[variantIndex];
                
                if (files.length > 0) {
                    if (!isNaN(variantIndex)) {
                        // New variants (numeric indices)
                        files.forEach(file => {
                            formData.append(`variants[${variantIndex}][images]`, file);
                        });
                    } else {
                        // Existing variants (MongoDB ObjectId)
                        files.forEach(file => {
                            formData.append(`existingVariants[${variantIndex}][newImages]`, file);
                        });
                    }
                }
            }

            // Submit form via fetch
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    Swal.fire({
                        title: 'Success!',
                        text: 'Product updated successfully!',
                        icon: 'success',
                        confirmButtonColor: '#1f2937'
                    }).then(() => {
                        window.location.href = '/admin/products';
                    });
                } else {
                    throw new Error('Server error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                isSubmitting = false; // Reset flag on error
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                Swal.fire({
                    title: 'Error',
                    text: 'Failed to update product. Please try again.',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
            });
        }

        // Expose submitEditForm globally for validation script
        window.submitForm = submitEditForm;
        
        // Add form submit event listener
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('editProductForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    console.log('Form submit event triggered');
                    submitEditForm();
                });
            }
        });

