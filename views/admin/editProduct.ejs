<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product - GEARGRID Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/public/css/text-wrap.css">
    <link rel="stylesheet" href="/public/css/admin-responsive.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Cropper.js CSS and JS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/croppie/2.6.5/croppie.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/croppie/2.6.5/croppie.min.js"></script>
    
    <!-- Product Form Validation -->
    <script src="/public/admin/productFormValidation.js"></script>
    
    <style>
        .croppie-container {
            max-height: 400px;
        }
        
        .file-processing {
            border-color: #3b82f6 !important;
            background-color: #eff6ff !important;
        }
        
        .file-ready {
            border-color: #10b981 !important;
            background-color: #ecfdf5 !important;
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/adminSidebar', { currentPage: 'products' }) %>

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <%- include('../partials/adminHeader', { admin: admin }) %>

            <!-- Main Content -->
            <main class="flex-1 overflow-y-auto p-6">
                <!-- Breadcrumb -->
                <div class="mb-6">
                    <div class="flex items-center text-sm text-gray-600 mb-4">
                        <a href="/admin/products" class="hover:text-gray-900">Products</a>
                        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        <span class="text-gray-900 font-medium">Edit Product</span>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900">Edit Product</h2>
                    <p class="text-sm text-gray-600 mt-1">Update product information and variants</p>
                </div>

                <!-- Error/Success Message -->
                <% if (message) { %>
                    <div class="mb-6 px-4 py-3 rounded-lg border flex items-center gap-3 <%= isError ? 'bg-red-50 border-red-200 text-red-800' : 'bg-green-50 border-green-200 text-green-800' %>">
                        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <% if (isError) { %>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                            <% } else { %>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            <% } %>
                        </svg>
                        <span><%= message %></span>
                    </div>
                <% } %>

                <!-- Edit Product Form -->
                <form id="editProductForm" action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                    
                    <!-- Product Name -->
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Product Name *</label>
                        <input 
                            type="text" 
                            name="productName" 
                            id="productName"
                            value="<%= product.productName %>"
                            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                        >
                        <p class="text-xs text-gray-500 mt-1">3-100 characters</p>
                        <p class="text-xs text-red-600 mt-1 hidden error-message" id="productName-error"></p>
                    </div>

                    <!-- Description -->
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Description *</label>
                        <textarea 
                            name="description" 
                            id="description"
                            rows="4"
                            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition resize-none"
                        ><%= product.description %></textarea>
                        <p class="text-xs text-gray-500 mt-1">10-1000 characters</p>
                        <p class="text-xs text-red-600 mt-1 hidden error-message" id="description-error"></p>
                    </div>

                    <!-- Category -->
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Category *</label>
                        <select 
                            name="category" 
                            id="category"
                            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                        >
                            <option value="">Select a category</option>
                            <% categories.forEach(category => { %>
                                <option value="<%= category._id %>" <%= product.category._id.toString() === category._id.toString() ? 'selected' : '' %>>
                                    <%= category.name %>
                                </option>
                            <% }); %>
                        </select>
                        <p class="text-xs text-red-600 mt-1 hidden error-message" id="category-error"></p>
                    </div>

                    <!-- Existing Variants Section -->
                    <div class="mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700">Product Variants</label>
                                <p class="text-xs text-gray-500 mt-1">Manage existing variants or add new ones</p>
                            </div>
                            <button 
                                type="button"
                                onclick="addNewVariant()"
                                class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition text-sm font-medium flex items-center gap-2"
                            >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                Add New Variant
                            </button>
                        </div>

                        <!-- Existing Variants Container -->
                        <div id="existingVariantsContainer" class="space-y-4 mb-4">
                            <% if (product.variants && product.variants.length > 0) { %>
                                <% product.variants.forEach((variant, index) => { %>
                                    <div class="variant-item border border-gray-300 rounded-lg p-5 bg-gray-50" data-variant-id="<%= variant._id %>" data-variant-index="<%= variant._id %>">
                                        <div class="flex items-center justify-between mb-4">
                                            <h3 class="text-sm font-semibold text-gray-700">Existing Variant: <%= variant.color %></h3>
                                            <button 
                                                type="button"
                                                onclick="deleteExistingVariant(this, '<%= variant._id %>')"
                                                class="text-red-600 hover:text-red-800 text-sm font-medium flex items-center gap-1"
                                            >
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                Delete
                                            </button>
                                        </div>

                                        <div class="grid grid-cols-2 gap-4 mb-4">
                                            <div>
                                                <label class="block text-xs font-medium text-gray-700 mb-1">Color *</label>
                                                <input 
                                                    type="text" 
                                                    name="existingVariants[<%= variant._id %>][color]" 
                                                    value="<%= variant.color %>"
                                                    data-color
                                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                                >
                                                <p class="color-error text-xs text-red-600 mt-1 hidden"></p>
                                                <p class="text-xs text-gray-500 mt-1">Enter color name</p>
                                            </div>

                                            <div>
                                                <label class="block text-xs font-medium text-gray-700 mb-1">Stock Quantity *</label>
                                                <input 
                                                    type="number" 
                                                    name="existingVariants[<%= variant._id %>][quantity]" 
                                                    value="<%= variant.quantity %>"
                                                    data-stock
                                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                                >
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-2 gap-4 mb-4">
                                            <div>
                                                <label class="block text-xs font-medium text-gray-700 mb-1">Regular Price (₹) *</label>
                                                <input 
                                                    type="number" 
                                                    name="existingVariants[<%= variant._id %>][regularPrice]" 
                                                    value="<%= variant.regularPrice %>"
                                                    data-regular
                                                    step="0.01"
                                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                                >
                                            </div>

                                            <div>
                                                <label class="block text-xs font-medium text-gray-700 mb-1">Sale Price (₹) *</label>
                                                <input 
                                                    type="number" 
                                                    name="existingVariants[<%= variant._id %>][salePrice]" 
                                                    value="<%= variant.salePrice %>"
                                                    data-sale
                                                    step="0.01"
                                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                                >
                                            </div>
                                        </div>
                                        
                                        <!-- Price Error Message -->
                                        <p class="price-error text-xs text-red-600 mt-1 hidden"></p>

                                        <!-- Current Images -->
                                        <div class="mb-4">
                                            <label class="block text-xs font-medium text-gray-700 mb-2">Current Images</label>
                                            <div class="flex gap-2 flex-wrap" id="currentImages_<%= variant._id %>">
                                                <% variant.images.forEach((image, imgIndex) => { %>
                                                    <div class="relative group" data-image-url="<%= image %>">
                                                        <img 
                                                            src="<%= image %>" 
                                                            alt="<%= variant.color %>"
                                                            class="w-20 h-20 object-cover rounded-lg border border-gray-200"
                                                        >
                                                        <button 
                                                            type="button"
                                                            onclick="removeExistingImage(this, '<%= variant._id %>', '<%= image %>')"
                                                            class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-red-600"
                                                            title="Remove image"
                                                        >
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                            </svg>
                                                        </button>
                                                    </div>
                                                <% }); %>
                                            </div>
                                            <!-- Hidden field to track removed images -->
                                            <input type="hidden" name="existingVariants[<%= variant._id %>][removedImages]" id="removedImages_<%= variant._id %>" value="">
                                        </div>

                                        <!-- Add New Images -->
                                        <div>
                                            <label class="block text-xs font-medium text-gray-700 mb-2">Add New Images (Optional)</label>
                                            <div class="border-2 border-dashed border-gray-300 rounded-lg p-3 text-center hover:border-gray-400 transition">
                                                <input 
                                                    type="file" 
                                                    name="existingVariants[<%= variant._id %>][newImages]" 
                                                    multiple
                                                    accept="image/*"
                                                    class="hidden"
                                                    id="addImages_<%= variant._id %>"
                                                    onchange="handleImageSelect(event, '<%= variant._id %>')"
                                                >
                                                <label for="addImages_<%= variant._id %>" class="cursor-pointer">
                                                    <svg class="w-6 h-6 mx-auto text-gray-400 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                                    </svg>
                                                    <p class="text-xs text-gray-600">Click to add more images</p>
                                                </label>
                                                <div id="addImagesList_<%= variant._id %>" class="mt-2 text-xs text-gray-600"></div>
                                            </div>
                                            <div id="imagePreview_<%= variant._id %>" class="mt-3 grid grid-cols-3 gap-2"></div>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p class="text-sm text-gray-500 text-center py-4">No variants yet. Click "Add New Variant" to create one.</p>
                            <% } %>
                        </div>

                        <!-- New Variants Container -->
                        <div id="newVariantsContainer" class="space-y-4"></div>

                        <!-- Hidden field for deleted variants -->
                        <input type="hidden" name="deletedVariants" id="deletedVariants" value="">
                    </div>

                    <!-- Buttons -->
                    <div class="flex gap-3 pt-4 border-t border-gray-200">
                        <button 
                            type="submit"
                            id="submitBtn"
                            class="flex-1 px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition font-medium flex items-center justify-center gap-2"
                        >
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            <span>Update Product</span>
                        </button>
                        <a 
                            href="/admin/products"
                            class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition font-medium"
                        >
                            Cancel
                        </a>
                    </div>
                </form>
            </main>
        </div>
    </div>

    <!-- Image Cropping Modal -->
    <div id="cropModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-lg max-w-2xl w-full max-h-[90vh] overflow-hidden">
            <div class="flex items-center justify-between p-4 border-b">
                <h3 class="text-lg font-semibold text-gray-900">Crop Image</h3>
                <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            
            <div class="p-4">
                <div id="croppie-container" class="mb-4"></div>
                
                <div class="flex justify-end gap-3">
                    <button onclick="closeCropModal()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition">
                        Cancel
                    </button>
                    <button onclick="cropAndNext()" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
                        <i class="fas fa-check mr-2"></i>Crop & Next
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let newVariantCount = 0;
        let deletedVariantIds = [];
        let currentCroppie = null;
        let currentVariantIndex = null;
        let currentFileIndex = 0;
        let filesToProcess = [];
        let croppedFiles = {};

        // Initialize cropped files for existing variants
        <% if (product.variants && product.variants.length > 0) { %>
            <% product.variants.forEach((variant, index) => { %>
                croppedFiles['<%= variant._id %>'] = [];
            <% }); %>
        <% } %>
        
        // Price validation function
        function validatePrices(variantElement) {
            const regularPriceInput = variantElement.querySelector('[data-regular]');
            const salePriceInput = variantElement.querySelector('[data-sale]');
            const priceError = variantElement.querySelector('.price-error');
            
            if (!regularPriceInput || !salePriceInput || !priceError) return true;
            
            const regularPrice = parseFloat(regularPriceInput.value) || 0;
            const salePrice = parseFloat(salePriceInput.value) || 0;
            
            if (salePrice > regularPrice && regularPrice > 0) {
                priceError.textContent = `Sale price (₹${salePrice}) cannot exceed regular price (₹${regularPrice})`;
                priceError.classList.remove('hidden');
                salePriceInput.classList.add('border-red-500');
                return false;
            } else {
                priceError.textContent = '';
                priceError.classList.add('hidden');
                salePriceInput.classList.remove('border-red-500');
                return true;
            }
        }
        
        // Setup price validation for a variant
        function setupPriceValidation(variantElement) {
            const regularPriceInput = variantElement.querySelector('[data-regular]');
            const salePriceInput = variantElement.querySelector('[data-sale]');
            
            if (regularPriceInput && salePriceInput) {
                regularPriceInput.addEventListener('input', () => validatePrices(variantElement));
                salePriceInput.addEventListener('input', () => validatePrices(variantElement));
                regularPriceInput.addEventListener('blur', () => validatePrices(variantElement));
                salePriceInput.addEventListener('blur', () => validatePrices(variantElement));
            }
        }
        
        // Initialize price validation for existing variants on page load
        document.addEventListener('DOMContentLoaded', function() {
            const existingVariants = document.querySelectorAll('[data-variant-id]');
            existingVariants.forEach(variant => {
                setupPriceValidation(variant);
            });
        });

        function addNewVariant() {
            const container = document.getElementById('newVariantsContainer');
            const variantIndex = newVariantCount;
            
            const variantHTML = `
                <div class="variant-item border border-green-300 rounded-lg p-5 bg-green-50" data-new-variant-index="${variantIndex}">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-semibold text-gray-700">New Variant #${variantIndex + 1}</h3>
                        <button 
                            type="button"
                            onclick="removeNewVariant(this)"
                            class="text-red-600 hover:text-red-800 text-sm font-medium flex items-center gap-1"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Remove
                        </button>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Color *</label>
                            <input 
                                type="text" 
                                name="variants[${variantIndex}][color]" 
                                data-color
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="e.g., Black, White, Red"
                            >
                            <p class="color-error text-xs text-red-600 mt-1 hidden"></p>
                            <p class="text-xs text-gray-500 mt-1">Enter color name</p>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Stock Quantity *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][quantity]" 
                                data-stock
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0"
                            >
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Regular Price (₹) *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][regularPrice]" 
                                data-regular
                                step="0.01"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0.00"
                            >
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Sale Price (₹) *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][salePrice]" 
                                data-sale
                                step="0.01"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0.00"
                            >
                        </div>
                    </div>
                    
                    <!-- Price Error Message -->
                    <p class="price-error text-xs text-red-600 mt-1 hidden"></p>

                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-2">Variant Images * (Min 3, Max 5)</label>
                        <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-gray-400 transition">
                            <input 
                                type="file" 
                                name="variants[${variantIndex}][images]" 
                                multiple
                                accept="image/*"
                                class="hidden variant-images"
                                id="newVariantImages${variantIndex}"
                                onchange="handleImageSelect(event, ${variantIndex})"
                            >
                            <label for="newVariantImages${variantIndex}" class="cursor-pointer">
                                <svg class="w-8 h-8 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                                </svg>
                                <p class="text-xs text-gray-600 mb-1">Click to upload images</p>
                                <p class="text-xs text-gray-500">PNG, JPG, WEBP (Max 5)</p>
                            </label>
                            <div id="newVariantFileList${variantIndex}" class="mt-2 text-xs text-gray-600"></div>
                        </div>
                        <div id="imagePreview${variantIndex}" class="mt-3 grid grid-cols-3 gap-2"></div>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', variantHTML);
            croppedFiles[variantIndex] = [];
            newVariantCount++;
            
            // Setup price validation for the new variant
            const newVariantElement = container.lastElementChild;
            setupPriceValidation(newVariantElement);
            
            // Update submit button state
            updateSubmitButtonState();
        }

        function removeNewVariant(button) {
            const variantItem = button.closest('.variant-item');
            const variantIndex = variantItem.getAttribute('data-new-variant-index');
            delete croppedFiles[variantIndex];
            variantItem.remove();
            
            // Update submit button state
            updateSubmitButtonState();
        }

        // Handle Image Selection
        function handleImageSelect(event, variantIndex) {
            const files = event.target.files;
            
            // Validate file count
            if (files.length > 5) {
                Swal.fire({
                    title: 'Too Many Images',
                    text: 'You can only upload a maximum of 5 images per variant.',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                event.target.value = '';
                return;
            }

            // Validate file size (5MB each)
            for (let file of files) {
                if (file.size > 5 * 1024 * 1024) {
                    Swal.fire({
                        title: 'File Too Large',
                        text: `${file.name} is larger than 5MB. Please choose smaller images.`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    event.target.value = '';
                    return;
                }
            }

            currentVariantIndex = variantIndex;
            filesToProcess = Array.from(files);
            currentFileIndex = 0;
            croppedFiles[variantIndex] = [];

            if (filesToProcess.length > 0) {
                processNextImage();
            }
        }

        // Process Next Image
        function processNextImage() {
            if (currentFileIndex >= filesToProcess.length) {
                updateImagePreview();
                const input = document.getElementById(`newVariantImages${currentVariantIndex}`) || 
                             document.getElementById(`addImages_${currentVariantIndex}`);
                if (input) input.value = '';
                return;
            }

            const file = filesToProcess[currentFileIndex];
            const reader = new FileReader();
            
            reader.onload = function(e) {
                showCropModal(e.target.result);
            };
            reader.readAsDataURL(file);
        }

        // Show Crop Modal
        function showCropModal(imageSrc) {
            const modal = document.getElementById('cropModal');
            const container = document.getElementById('croppie-container');
            
            modal.classList.remove('hidden');
            
            if (currentCroppie) {
                currentCroppie.destroy();
            }
            
            currentCroppie = new Croppie(container, {
                viewport: { width: 300, height: 300, type: 'square' },
                boundary: { width: 400, height: 400 },
                showZoomer: true,
                enableResize: false,
                enableOrientation: true,
                mouseWheelZoom: 'ctrl'
            });
            
            currentCroppie.bind({
                url: imageSrc
            });
        }

        // Crop and Next
        function cropAndNext() {
            if (!currentCroppie) return;
            
            currentCroppie.result({
                type: 'blob',
                size: { width: 800, height: 800 },
                format: 'jpeg',
                quality: 0.9
            }).then(function(blob) {
                const fileName = `cropped_${currentVariantIndex}_${currentFileIndex}.jpg`;
                const file = new File([blob], fileName, { type: 'image/jpeg' });
                
                croppedFiles[currentVariantIndex].push(file);
                currentFileIndex++;
                
                closeCropModal();
                
                setTimeout(() => {
                    processNextImage();
                }, 100);
            });
        }

        // Close Crop Modal
        function closeCropModal() {
            const modal = document.getElementById('cropModal');
            modal.classList.add('hidden');
            
            if (currentCroppie) {
                currentCroppie.destroy();
                currentCroppie = null;
            }
        }

        // Update Image Preview
        function updateImagePreview() {
            const preview = document.getElementById(`imagePreview${currentVariantIndex}`) || 
                           document.getElementById(`imagePreview_${currentVariantIndex}`);
            if (!preview) return;
            
            preview.innerHTML = '';

            const files = croppedFiles[currentVariantIndex] || [];
            files.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const imgDiv = document.createElement('div');
                    imgDiv.className = 'relative group';
                    imgDiv.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-20 object-cover rounded border">
                        <button type="button" onclick="removeImage('${currentVariantIndex}', ${index})" 
                                class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="fas fa-times text-xs"></i>
                        </button>
                    `;
                    preview.appendChild(imgDiv);
                };
                reader.readAsDataURL(file);
            });
            
            // Show feedback message about image count for new variants
            if (!isNaN(currentVariantIndex)) {
                showImageCountFeedback(currentVariantIndex, files.length, false);
            } else {
                // For existing variants, count existing + new images
                const variantItem = document.querySelector(`[data-variant-id="${currentVariantIndex}"]`);
                if (variantItem) {
                    const currentImagesContainer = document.getElementById(`currentImages_${currentVariantIndex}`);
                    const existingCount = currentImagesContainer ? currentImagesContainer.querySelectorAll('[data-image-url]').length : 0;
                    showImageCountFeedback(currentVariantIndex, existingCount + files.length, true);
                }
            }
        }
        
        // Show image count feedback
        function showImageCountFeedback(variantIndex, count, isExisting) {
            const variantItem = document.querySelector(`[data-variant-${isExisting ? 'id' : 'new-variant-index'}="${variantIndex}"]`);
            if (!variantItem) return;
            
            // Remove existing feedback
            const existingFeedback = variantItem.querySelector('.image-count-feedback');
            if (existingFeedback) {
                existingFeedback.remove();
            }
            
            // Create feedback message
            const feedbackDiv = document.createElement('div');
            feedbackDiv.className = 'image-count-feedback mt-2 p-2 rounded-lg text-sm font-medium';
            
            if (count < 3) {
                feedbackDiv.className += ' bg-red-50 text-red-700 border border-red-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-exclamation-circle mr-1"></i>
                    Need ${3 - count} more image(s). Minimum 3 images required. (Currently: ${count})
                `;
            } else if (count >= 3 && count < 5) {
                feedbackDiv.className += ' bg-green-50 text-green-700 border border-green-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-check-circle mr-1"></i>
                    ${count} images added. You can add ${5 - count} more. (Min: 3, Max: 5)
                `;
            } else {
                feedbackDiv.className += ' bg-blue-50 text-blue-700 border border-blue-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-info-circle mr-1"></i>
                    Maximum 5 images reached.
                `;
            }
            
            // Insert after the last image-related element
            const preview = document.getElementById(`imagePreview${variantIndex}`) || 
                           document.getElementById(`imagePreview_${variantIndex}`);
            if (preview && preview.parentElement) {
                preview.parentElement.appendChild(feedbackDiv);
            }
            
            // Update submit button state
            updateSubmitButtonState();
        }
        
        // Check if form is valid and update submit button
        function updateSubmitButtonState() {
            const submitBtn = document.getElementById('submitBtn');
            if (!submitBtn) return;
            
            let hasErrors = false;
            let errorMessage = '';
            
            // Check product name
            const productNameInput = document.getElementById('productName');
            if (productNameInput) {
                const value = productNameInput.value.trim();
                
                // Check if only special characters/symbols
                if (value.length > 0 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(value)) {
                    hasErrors = true;
                    errorMessage = 'Product name cannot contain only symbols and numbers';
                } else if (value.length > 0 && value.length < 3) {
                    hasErrors = true;
                    errorMessage = 'Product name must be at least 3 characters';
                }
            }
            
            // Check description
            if (!hasErrors) {
                const descriptionInput = document.getElementById('description');
                if (descriptionInput) {
                    const value = descriptionInput.value.trim();
                    
                    // Check if only special characters/symbols
                    if (value.length > 0 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(value)) {
                        hasErrors = true;
                        errorMessage = 'Description cannot contain only symbols and numbers';
                    } else if (value.length > 0 && value.length < 10) {
                        hasErrors = true;
                        errorMessage = 'Description must be at least 10 characters';
                    }
                }
            }
            
            // Check category
            if (!hasErrors) {
                const categoryInput = document.getElementById('category');
                if (categoryInput && !categoryInput.value) {
                    hasErrors = true;
                    errorMessage = 'Please select a category';
                }
            }
            
            // Check variants for color validation
            if (!hasErrors) {
                const allVariants = [...document.querySelectorAll('[data-variant-id]'), ...document.querySelectorAll('[data-new-variant-index]')];
                for (let variant of allVariants) {
                    const colorInput = variant.querySelector('[data-color]');
                    if (colorInput) {
                        const color = colorInput.value.trim();
                        if (color.length > 0 && color.length < 2) {
                            hasErrors = true;
                            errorMessage = 'All colors must be at least 2 characters';
                            break;
                        }
                        if (color.length >= 2 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(color)) {
                            hasErrors = true;
                            errorMessage = 'Invalid color detected. Use proper color names with letters';
                            break;
                        }
                    }
                }
            }
            
            // Check existing variants
            if (!hasErrors) {
                const existingVariants = document.querySelectorAll('[data-variant-id]');
                for (let variant of existingVariants) {
                    const variantId = variant.getAttribute('data-variant-id');
                    
                    // Count existing images
                    const currentImagesContainer = document.getElementById(`currentImages_${variantId}`);
                    const existingImages = currentImagesContainer ? currentImagesContainer.querySelectorAll('[data-image-url]').length : 0;
                    
                    // Count new images
                    const newImages = croppedFiles[variantId] ? croppedFiles[variantId].length : 0;
                    
                    const totalImages = existingImages + newImages;
                    
                    if (totalImages < 3) {
                        hasErrors = true;
                        errorMessage = 'All variants must have minimum 3 images';
                        break;
                    }
                }
            }
            
            // Check new variants
            if (!hasErrors) {
                const newVariants = document.querySelectorAll('[data-new-variant-index]');
                for (let variant of newVariants) {
                    const variantIndex = variant.getAttribute('data-new-variant-index');
                    const images = croppedFiles[variantIndex] ? croppedFiles[variantIndex].length : 0;
                    
                    if (images < 3) {
                        hasErrors = true;
                        errorMessage = 'All variants must have minimum 3 images';
                        break;
                    }
                }
            }
            
            // Check price validation
            if (!hasErrors) {
                const allVariants = [...document.querySelectorAll('[data-variant-id]'), ...document.querySelectorAll('[data-new-variant-index]')];
                for (let variant of allVariants) {
                    const regularInput = variant.querySelector('[data-regular]');
                    const saleInput = variant.querySelector('[data-sale]');
                    
                    if (regularInput && saleInput) {
                        const regular = parseFloat(regularInput.value) || 0;
                        const sale = parseFloat(saleInput.value) || 0;
                        
                        if (sale > regular && regular > 0) {
                            hasErrors = true;
                            errorMessage = 'Sale price cannot exceed regular price';
                            break;
                        }
                    }
                }
            }
            
            // Disable/enable button based on validation
            if (hasErrors) {
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                submitBtn.title = errorMessage;
            } else {
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                submitBtn.title = '';
            }
        }

        // Remove Image
        function removeImage(variantIndex, imageIndex) {
            croppedFiles[variantIndex].splice(imageIndex, 1);
            currentVariantIndex = variantIndex;
            updateImagePreview();
        }

