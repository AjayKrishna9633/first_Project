                        categoryError.classList.add('hidden');
                    }
                    updateSubmitButtonState();
                });
            }
            
            // Initialize submit button state
            updateSubmitButtonState();
        });
        
        // Real-time Price and Color Validation
        document.addEventListener('input', function(e) {
            const variant = e.target.closest('.variant-item');
            if (!variant) return;
            
            // Price validation
            const regularInput = variant.querySelector('[data-regular]');
            const saleInput = variant.querySelector('[data-sale]');
            const priceErrorMsg = variant.querySelector('.price-error');
            
            if (regularInput && saleInput && priceErrorMsg) {
                const regular = parseFloat(regularInput.value) || 0;
                const sale = parseFloat(saleInput.value) || 0;
                
                if (sale > regular && regular > 0) {
                    saleInput.classList.add('border-red-500');
                    priceErrorMsg.textContent = `Sale price cannot exceed ₹${regular}`;
                    priceErrorMsg.classList.remove('hidden');
                } else {
                    saleInput.classList.remove('border-red-500');
                    priceErrorMsg.classList.add('hidden');
                }
            }
            
            // Color validation
            if (e.target.hasAttribute('data-color')) {
                const colorInput = e.target;
                const colorError = variant.querySelector('.color-error');
                const color = colorInput.value.trim();
                
                if (colorError) {
                    if (color.length > 0 && color.length < 2) {
                        colorInput.classList.add('border-red-500');
                        colorError.textContent = 'Color must be at least 2 characters';
                        colorError.classList.remove('hidden');
                    } else if (color.length >= 2 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~0-9]+$/.test(color)) {
                        colorInput.classList.add('border-red-500');
                        colorError.textContent = 'Invalid color. Use proper color names with letters (e.g., Black, Red)';
                        colorError.classList.remove('hidden');
                    } else {
                        colorInput.classList.remove('border-red-500');
                        colorError.classList.add('hidden');
                    }
                }
            }
            
            updateSubmitButtonState();
        });
    </script>
</body>
</html>
