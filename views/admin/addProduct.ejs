<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - GEARGRID Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/public/css/text-wrap.css">
    <link rel="stylesheet" href="/public/css/admin-responsive.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Croppie CSS and JS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/croppie/2.6.5/croppie.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/croppie/2.6.5/croppie.min.js"></script>
    
    <style>
        .croppie-container {
            max-height: 400px;
        }
    </style>
    
    <!-- Product Form Validation Script -->
    <script src="/public/admin/productFormValidation.js" defer></script>
</head>
<body class="bg-gray-50">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/adminSidebar', { currentPage: 'products' }) %>

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <%- include('../partials/adminHeader', { admin: admin }) %>

            <!-- Main Content -->
            <main class="flex-1 overflow-y-auto p-6">
                <!-- Page Header -->
                <div class="mb-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="flex items-center text-sm text-gray-600 mb-4">
                                <a href="/admin/products" class="hover:text-gray-900">Products</a>
                                <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                <span class="text-gray-900 font-medium">Add New Product</span>
                            </div>
                            <h2 class="text-2xl font-bold text-gray-900">Add New Product</h2>
                            <p class="text-sm text-gray-600 mt-1">Create a new product for your store</p>
                        </div>
                        <button 
                            type="submit"
                            form="addProductForm"
                            id="submitBtn"
                            class="px-3 py-1.5 bg-gray-900 text-white rounded text-sm font-medium hover:bg-gray-800 transition"
                        >
                            Add Product
                        </button>
                    </div>
                </div>

                <!-- Error/Success Message -->
                <% if (message) { %>
                    <div class="mb-6 px-4 py-3 rounded-lg border flex items-center gap-3 <%= isError ? 'bg-red-50 border-red-200 text-red-800' : 'bg-green-50 border-green-200 text-green-800' %>">
                        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <% if (isError) { %>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                            <% } else { %>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            <% } %>
                        </svg>
                        <span><%= message %></span>
                    </div>
                <% } %>

                <!-- Product Form -->
                <form id="addProductForm" action="/admin/products/add" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                    
                    <!-- Basic Product Information -->
                    <div class="grid grid-cols-1 gap-6 mb-8">
                        <!-- Product Name -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Product Name *</label>
                            <input 
                                type="text" 
                                name="productName" 
                                id="productName"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                                placeholder="e.g., Gaming Keyboard RGB"
                            >
                            <p class="text-xs text-gray-500 mt-1">3-100 characters</p>
                            <p class="text-xs text-red-600 mt-1 hidden" id="productName-error"></p>
                        </div>

                        <!-- Description -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Description *</label>
                            <textarea 
                                name="description" 
                                id="description"
                                rows="4"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition resize-none"
                                placeholder="Describe your product features, specifications, and benefits..."
                            ></textarea>
                            <p class="text-xs text-gray-500 mt-1">10-1000 characters</p>
                            <p class="text-xs text-red-600 mt-1 hidden" id="description-error"></p>
                        </div>

                        <!-- Category -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Category *</label>
                            <select 
                                name="category" 
                                id="category"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                            >
                                <option value="">Select a category</option>
                                <% categories.forEach(category => { %>
                                    <option value="<%= category._id %>"><%= category.name %></option>
                                <% }); %>
                            </select>
                            <p class="text-xs text-red-600 mt-1 hidden" id="category-error"></p>
                        </div>
                    </div>

                    <!-- Product Variants Section -->
                    <div class="mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700">Product Variants *</label>
                                <p class="text-xs text-gray-500 mt-1">Add different color variants with pricing and stock</p>
                            </div>
                            <button 
                                type="button"
                                onclick="addVariant()"
                                class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition text-sm font-medium flex items-center gap-2"
                            >
                                <i class="fas fa-plus text-xs"></i>
                                Add Variant
                            </button>
                        </div>

                        <!-- Variants Container -->
                        <div id="variantsContainer" class="space-y-4">
                            <!-- Initial Variant -->
                            <div class="variant-item border border-gray-300 rounded-lg p-5 bg-gray-50" data-variant-index="0">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-semibold text-gray-700">Variant #1</h3>
                                    <button 
                                        type="button"
                                        onclick="removeVariant(this)"
                                        class="text-red-600 hover:text-red-800 text-sm font-medium flex items-center gap-1"
                                    >
                                        <i class="fas fa-trash text-xs"></i>
                                        Remove
                                    </button>
                                </div>

                                <!-- Variant Fields -->
                                <div class="grid grid-cols-2 gap-4 mb-4">
                                    <div>
                                        <label class="block text-xs font-medium text-gray-700 mb-1">Color *</label>
                                        <input 
                                            type="text" 
                                            name="variants[0][color]" 
                                            data-color
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                            placeholder="e.g., Black, White, Red"
                                        >
                                        <p class="color-error text-xs text-red-600 mt-1 hidden"></p>
                                        <p class="text-xs text-gray-500 mt-1">Enter color name (e.g., Black, Red)</p>
                                    </div>

                                    <div>
                                        <label class="block text-xs font-medium text-gray-700 mb-1">Stock Quantity *</label>
                                        <input 
                                            type="number" 
                                            name="variants[0][quantity]" 
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                            placeholder="0"
                                        >
                                    </div>
                                </div>

                                <div class="grid grid-cols-2 gap-4 mb-4">
                                    <div>
                                        <label class="block text-xs font-medium text-gray-700 mb-1">Regular Price (₹) *</label>
                                        <input 
                                            type="number" 
                                            name="variants[0][regularPrice]" 
                                            data-regular
                                            step="0.01"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                            placeholder="0.00"
                                        >
                                    </div>

                                    <div>
                                        <label class="block text-xs font-medium text-gray-700 mb-1">Sale Price (₹) *</label>
                                        <input 
                                            type="number" 
                                            name="variants[0][salePrice]" 
                                            data-sale
                                            step="0.01"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                            placeholder="0.00"
                                        >
                                        <p class="price-error text-xs text-red-600 mt-1 hidden"></p>
                                    </div>
                                </div>

                                <!-- Variant Images -->
                                <div>
                                    <label class="block text-xs font-medium text-gray-700 mb-2">Variant Images * (Min 3, Max 5)</label>
                                    <input 
                                        type="file" 
                                        multiple
                                        accept="image/jpeg,image/jpg,image/png,image/webp"
                                        class="hidden variant-images-input"
                                        id="variantImagesInput0"
                                        onchange="handleImageSelect(event, 0)"
                                    >
                                    <button 
                                        type="button"
                                        onclick="document.getElementById('variantImagesInput0').click()"
                                        class="w-full border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-gray-400 transition"
                                    >
                                        <i class="fas fa-cloud-upload-alt text-2xl text-gray-400 mb-2"></i>
                                        <p class="text-xs text-gray-600 mb-1">Click to upload and crop images</p>
                                        <p class="text-xs text-gray-500">PNG, JPG, WEBP (Min 3, Max 5 images, 5MB each)</p>
                                    </button>
                                    <div id="imagePreview0" class="grid grid-cols-5 gap-2 mt-3"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </main>
        </div>
    </div>

    <!-- Image Crop Modal -->
    <div id="cropModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Crop Image</h3>
                <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
            <div id="cropContainer" class="mb-4" style="height: 400px;"></div>
            <div class="flex gap-3">
                <button onclick="cropImage()" class="flex-1 px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 font-medium">
                    Crop & Save
                </button>
                <button onclick="closeCropModal()" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 font-medium">
                    Cancel
                </button>
            </div>
        </div>
    </div>

    <script>
        // Check if Croppie is loaded
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, checking Croppie library...');
            
            if (typeof Croppie === 'undefined') {
                console.error('Croppie library not loaded!');
                Swal.fire({
                    title: 'Error',
                    text: 'Image cropping library failed to load. Please refresh the page.',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
            } else {
                console.log('Croppie library loaded successfully');
                console.log('Croppie version:', Croppie.version || 'Unknown');
            }
            
            // Also check if SweetAlert2 is loaded
            if (typeof Swal === 'undefined') {
                console.error('SweetAlert2 library not loaded!');
                alert('Required libraries failed to load. Please refresh the page.');
            } else {
                console.log('SweetAlert2 library loaded successfully');
            }
        });

        let variantCount = 1;
        let currentCroppie = null;
        let currentVariantIndex = null;
        let currentFileIndex = 0;
        let filesToProcess = [];
        let croppedFiles = { 0: [] };

        // Add New Variant
        function addVariant() {
            const container = document.getElementById('variantsContainer');
            const variantIndex = variantCount;
            
            const variantHTML = createVariantHTML(variantIndex);
            container.insertAdjacentHTML('beforeend', variantHTML);
            croppedFiles[variantIndex] = [];
            variantCount++;
            
            // Update submit button state
            updateSubmitButtonState();
        }

        // Create Variant HTML Template
        function createVariantHTML(variantIndex) {
            return `
                <div class="variant-item border border-gray-300 rounded-lg p-5 bg-gray-50" data-variant-index="${variantIndex}">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-semibold text-gray-700">Variant #${variantIndex + 1}</h3>
                        <button 
                            type="button"
                            onclick="removeVariant(this)"
                            class="text-red-600 hover:text-red-800 text-sm font-medium flex items-center gap-1"
                        >
                            <i class="fas fa-trash text-xs"></i>
                            Remove
                        </button>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Color *</label>
                            <input 
                                type="text" 
                                name="variants[${variantIndex}][color]" 
                                data-color
                                required
                                minlength="2"
                                maxlength="30"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="e.g., Black, White, Red"
                            >
                            <p class="color-error text-xs text-red-600 mt-1 hidden"></p>
                            <p class="text-xs text-gray-500 mt-1">Enter color name</p>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Stock Quantity *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][quantity]" 
                                required
                                min="0"
                                max="10000"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0"
                            >
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Regular Price (₹) *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][regularPrice]" 
                                data-regular
                                required
                                min="1"
                                max="1000000"
                                step="0.01"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0.00"
                            >
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Sale Price (₹) *</label>
                            <input 
                                type="number" 
                                name="variants[${variantIndex}][salePrice]" 
                                data-sale
                                required
                                min="1"
                                max="1000000"
                                step="0.01"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 text-sm"
                                placeholder="0.00"
                            >
                            <p class="price-error text-xs text-red-600 mt-1 hidden"></p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-2">Variant Images * (Min 3, Max 5)</label>
                        <input 
                            type="file" 
                            multiple
                            accept="image/jpeg,image/jpg,image/png,image/webp"
                            class="hidden variant-images-input"
                            id="variantImagesInput${variantIndex}"
                            onchange="handleImageSelect(event, ${variantIndex})"
                        >
                        <button 
                            type="button"
                            onclick="document.getElementById('variantImagesInput${variantIndex}').click()"
                            class="w-full border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-gray-400 transition"
                        >
                            <i class="fas fa-cloud-upload-alt text-2xl text-gray-400 mb-2"></i>
                            <p class="text-xs text-gray-600 mb-1">Click to upload and crop images</p>
                            <p class="text-xs text-gray-500">PNG, JPG, WEBP (Min 3, Max 5 images, 5MB each)</p>
                        </button>
                        <div id="imagePreview${variantIndex}" class="grid grid-cols-5 gap-2 mt-3"></div>
                    </div>
                </div>
            `;
        }

        // Remove Variant
        function removeVariant(button) {
            const variantsContainer = document.getElementById('variantsContainer');
            const variantItems = variantsContainer.querySelectorAll('.variant-item');
            
            if (variantItems.length <= 1) {
                Swal.fire({
                    title: 'Cannot Remove',
                    text: 'At least one variant is required!',
                    icon: 'warning',
                    confirmButtonColor: '#1f2937'
                });
                return;
            }
            
            const variantItem = button.closest('.variant-item');
            const variantIndex = variantItem.getAttribute('data-variant-index');
            delete croppedFiles[variantIndex];
            variantItem.remove();
            
            updateVariantNumbers();
            
            // Update submit button state
            updateSubmitButtonState();
        }

        // Update Variant Numbers
        function updateVariantNumbers() {
            const variantItems = document.querySelectorAll('.variant-item');
            variantItems.forEach((item, index) => {
                const title = item.querySelector('h3');
                title.textContent = `Variant #${index + 1}`;
            });
        }

        // Handle Image Selection
        function handleImageSelect(event, variantIndex) {
            const files = event.target.files;
            
            if (!files || files.length === 0) {
                console.log('No files selected');
                return;
            }
            
            console.log(`Processing ${files.length} files for variant ${variantIndex}`);
            
            // Validate file count
            if (files.length > 5) {
                Swal.fire({
                    title: 'Too Many Images',
                    text: 'Maximum 5 images allowed per variant',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                event.target.value = '';
                return;
            }

            // Validate file types and sizes
            const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
            const maxSize = 5 * 1024 * 1024; // 5MB
            
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                
                // Check file type
                if (!validTypes.includes(file.type)) {
                    Swal.fire({
                        title: 'Invalid File Type',
                        text: `${file.name} is not a valid image type. Please select only JPEG, PNG, or WEBP images.`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    event.target.value = '';
                    return;
                }
                
                // Check file size
                if (file.size > maxSize) {
                    Swal.fire({
                        title: 'File Too Large',
                        text: `${file.name} is larger than 5MB. Please choose smaller images.`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    event.target.value = '';
                    return;
                }
            }

            // Initialize processing
            currentVariantIndex = variantIndex;
            filesToProcess = Array.from(files);
            currentFileIndex = 0;
            
            // Ensure croppedFiles array exists
            if (!croppedFiles[variantIndex]) {
                croppedFiles[variantIndex] = [];
            } else {
                croppedFiles[variantIndex] = []; // Reset for new selection
            }

            console.log('Starting image processing...');
            if (filesToProcess.length > 0) {
                processNextImage();
            }
        }

        // Process Next Image
        function processNextImage() {
            if (currentFileIndex >= filesToProcess.length) {
                // All images processed
                console.log('All images processed, updating preview...');
                updateImagePreview();
                const input = document.getElementById(`variantImagesInput${currentVariantIndex}`);
                if (input) input.value = '';
                
                // Show success message
                const processedCount = croppedFiles[currentVariantIndex] ? croppedFiles[currentVariantIndex].length : 0;
                if (processedCount > 0) {
                    Swal.fire({
                        title: 'Images Processed!',
                        text: `${processedCount} image(s) cropped and ready`,
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
                return;
            }

            const file = filesToProcess[currentFileIndex];
            if (!file) {
                console.error('No file found at index:', currentFileIndex);
                currentFileIndex++;
                processNextImage();
                return;
            }
            
            console.log(`Processing image ${currentFileIndex + 1}/${filesToProcess.length}: ${file.name}`);
            
            const reader = new FileReader();
            reader.onload = function(e) {
                if (e.target && e.target.result) {
                    showCropModal(e.target.result);
                } else {
                    console.error('Failed to read file');
                    Swal.fire({
                        title: 'Error',
                        text: `Failed to read ${file.name}. Skipping to next image.`,
                        icon: 'warning',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    currentFileIndex++;
                    processNextImage();
                }
            };
            reader.onerror = function(error) {
                console.error('FileReader error:', error);
                Swal.fire({
                    title: 'Error',
                    text: `Error reading ${file.name}. Skipping to next image.`,
                    icon: 'warning',
                    timer: 2000,
                    showConfirmButton: false
                });
                currentFileIndex++;
                processNextImage();
            };
            reader.readAsDataURL(file);
        }

        // Show Crop Modal
        function showCropModal(imageData) {
            const modal = document.getElementById('cropModal');
            const container = document.getElementById('cropContainer');
            
            if (!modal || !container) {
                console.error('Crop modal elements not found');
                return;
            }
            
            modal.classList.remove('hidden');
            
            // Clear container
            container.innerHTML = '';
            
            // Destroy existing croppie if any
            if (currentCroppie) {
                try {
                    currentCroppie.destroy();
                } catch (error) {
                    console.error('Error destroying existing croppie:', error);
                }
                currentCroppie = null;
            }

            // Initialize new croppie
            try {
                currentCroppie = new Croppie(container, {
                    viewport: { width: 300, height: 300, type: 'square' },
                    boundary: { width: 400, height: 400 },
                    enableOrientation: true,
                    enableResize: false,
                    showZoomer: true,
                    mouseWheelZoom: 'ctrl'
                });

                currentCroppie.bind({ 
                    url: imageData 
                }).catch(function(err) {
                    console.error('Error binding image to croppie:', err);
                    Swal.fire({
                        title: 'Error',
                        text: 'Failed to load image for cropping',
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    closeCropModal();
                });
            } catch (error) {
                console.error('Error initializing croppie:', error);
                Swal.fire({
                    title: 'Error',
                    text: 'Failed to initialize image cropper',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                closeCropModal();
            }
        }

        // Crop Image
        function cropImage() {
            if (!currentCroppie) {
                console.error('No croppie instance found');
                return;
            }

            try {
                currentCroppie.result({
                    type: 'blob',
                    size: { width: 800, height: 800 },
                    format: 'jpeg',
                    quality: 0.9
                }).then(function(blob) {
                    if (!blob) {
                        console.error('Failed to get cropped image blob');
                        return;
                    }
                    
                    const fileName = `cropped_${currentVariantIndex}_${currentFileIndex}.jpg`;
                    const file = new File([blob], fileName, { type: 'image/jpeg' });
                    
                    // Ensure croppedFiles array exists
                    if (!croppedFiles[currentVariantIndex]) {
                        croppedFiles[currentVariantIndex] = [];
                    }
                    
                    croppedFiles[currentVariantIndex].push(file);
                    currentFileIndex++;
                    
                    closeCropModal();
                    
                    // Process next image after a short delay
                    setTimeout(() => {
                        processNextImage();
                    }, 100);
                }).catch(function(error) {
                    console.error('Error cropping image:', error);
                    Swal.fire({
                        title: 'Error',
                        text: 'Failed to crop image. Please try again.',
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                });
            } catch (error) {
                console.error('Error in cropImage function:', error);
                Swal.fire({
                    title: 'Error',
                    text: 'Failed to crop image. Please try again.',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
            }
        }

        // Close Crop Modal
        function closeCropModal() {
            const modal = document.getElementById('cropModal');
            if (modal) {
                modal.classList.add('hidden');
            }
            
            if (currentCroppie) {
                try {
                    currentCroppie.destroy();
                } catch (error) {
                    console.error('Error destroying croppie:', error);
                }
                currentCroppie = null;
            }
            
            // Clear container
            const container = document.getElementById('cropContainer');
            if (container) {
                container.innerHTML = '';
            }
        }

        // Update Image Preview
        function updateImagePreview() {
            const preview = document.getElementById(`imagePreview${currentVariantIndex}`);
            preview.innerHTML = '';

            const files = croppedFiles[currentVariantIndex] || [];
            files.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const imgDiv = document.createElement('div');
                    imgDiv.className = 'relative group';
                    imgDiv.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-20 object-cover rounded-lg border border-gray-200">
                        <button 
                            type="button" 
                            onclick="removeImage(${currentVariantIndex}, ${index})" 
                            class="absolute top-1 right-1 bg-red-500 text-white rounded-full w-6 h-6 text-xs opacity-0 group-hover:opacity-100 transition flex items-center justify-center hover:bg-red-600"
                        >×</button>
                    `;
                    preview.appendChild(imgDiv);
                };
                reader.readAsDataURL(file);
            });
            
            // Show feedback message about image count
            showImageCountFeedback(currentVariantIndex, files.length);
        }
        
        // Show image count feedback
        function showImageCountFeedback(variantIndex, count) {
            const variantItem = document.querySelector(`[data-variant-index="${variantIndex}"]`);
            if (!variantItem) return;
            
            // Remove existing feedback
            const existingFeedback = variantItem.querySelector('.image-count-feedback');
            if (existingFeedback) {
                existingFeedback.remove();
            }
            
            // Create feedback message
            const feedbackDiv = document.createElement('div');
            feedbackDiv.className = 'image-count-feedback mt-2 p-2 rounded-lg text-sm font-medium';
            
            if (count < 3) {
                feedbackDiv.className += ' bg-red-50 text-red-700 border border-red-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-exclamation-circle mr-1"></i>
                    Need ${3 - count} more image(s). Minimum 3 images required. (Currently: ${count})
                `;
            } else if (count >= 3 && count < 5) {
                feedbackDiv.className += ' bg-green-50 text-green-700 border border-green-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-check-circle mr-1"></i>
                    ${count} images added. You can add ${5 - count} more. (Min: 3, Max: 5)
                `;
            } else {
                feedbackDiv.className += ' bg-blue-50 text-blue-700 border border-blue-200';
                feedbackDiv.innerHTML = `
                    <i class="fas fa-info-circle mr-1"></i>
                    Maximum 5 images reached.
                `;
            }
            
            // Insert after the preview container
            const preview = document.getElementById(`imagePreview${variantIndex}`);
            if (preview && preview.parentElement) {
                preview.parentElement.appendChild(feedbackDiv);
            }
            
            // Update submit button state
            updateSubmitButtonState();
        }
        
        // Check if form is valid and update submit button
        function updateSubmitButtonState() {
            const submitBtn = document.getElementById('submitBtn');
            if (!submitBtn) return;
            
            let hasErrors = false;
            let errorMessage = '';
            
            // Check product name
            const productNameInput = document.getElementById('productName');
            if (productNameInput) {
                const value = productNameInput.value.trim();
                if (value.length > 0 && value.length < 3) {
                    hasErrors = true;
                    errorMessage = 'Product name must be at least 3 characters';
                }
            }
            
            // Check description
            if (!hasErrors) {
                const descriptionInput = document.getElementById('description');
                if (descriptionInput) {
                    const value = descriptionInput.value.trim();
                    if (value.length > 0 && value.length < 10) {
                        hasErrors = true;
                        errorMessage = 'Description must be at least 10 characters';
                    }
                }
            }
            
            // Check category
            if (!hasErrors) {
                const categoryInput = document.getElementById('category');
                if (categoryInput && !categoryInput.value) {
                    hasErrors = true;
                    errorMessage = 'Please select a category';
                }
            }
            
            // Check variants for color validation
            if (!hasErrors) {
                const variantItems = document.querySelectorAll('.variant-item');
                for (let item of variantItems) {
                    const colorInput = item.querySelector('[data-color]');
                    if (colorInput) {
                        const color = colorInput.value.trim();
                        if (color.length > 0 && color.length < 2) {
                            hasErrors = true;
                            errorMessage = 'All colors must be at least 2 characters';
                            break;
                        }
                        if (color.length >= 2 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~]+$/.test(color)) {
                            hasErrors = true;
                            errorMessage = 'Invalid color detected. Use proper color names';
                            break;
                        }
                    }
                }
            }
            
            // Check each variant for minimum images
            if (!hasErrors) {
                const variantItems = document.querySelectorAll('.variant-item');
                for (let item of variantItems) {
                    const variantIndex = item.getAttribute('data-variant-index');
                    const files = croppedFiles[variantIndex] || [];
                    
                    if (files.length < 3) {
                        hasErrors = true;
                        errorMessage = 'All variants must have minimum 3 images';
                        break;
                    }
                }
            }
            
            // Check price validation
            if (!hasErrors) {
                const variantItems = document.querySelectorAll('.variant-item');
                for (let item of variantItems) {
                    const regularInput = item.querySelector('[data-regular]');
                    const saleInput = item.querySelector('[data-sale]');
                    
                    if (regularInput && saleInput) {
                        const regular = parseFloat(regularInput.value) || 0;
                        const sale = parseFloat(saleInput.value) || 0;
                        
                        if (sale > regular && regular > 0) {
                            hasErrors = true;
                            errorMessage = 'Sale price cannot exceed regular price';
                            break;
                        }
                    }
                }
            }
            
            // Disable/enable button based on validation
            if (hasErrors) {
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                submitBtn.title = errorMessage;
            } else {
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                submitBtn.title = '';
            }
        }

        // Remove Image
        function removeImage(variantIndex, imageIndex) {
            croppedFiles[variantIndex].splice(imageIndex, 1);
            currentVariantIndex = variantIndex;
            updateImagePreview();
        }

        // Form Validation and Submission
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('#addProductForm');
            
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                if (!validateForm()) return;
                
                submitForm();
            });
            
            // Initialize submit button state
            updateSubmitButtonState();
        });

        // Validate Form
        function validateForm() {
            // Validate product name
            const productNameInput = document.querySelector('input[name="productName"]');
            const productName = productNameInput.value.trim();
            
            if (productName.length < 3) {
                Swal.fire({
                    title: 'Invalid Product Name',
                    text: 'Product name must be at least 3 characters long',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                productNameInput.focus();
                return false;
            }
            
            // Validate description
            const descriptionInput = document.querySelector('textarea[name="description"]');
            const description = descriptionInput.value.trim();
            
            if (description.length < 10) {
                Swal.fire({
                    title: 'Invalid Description',
                    text: 'Description must be at least 10 characters long',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                descriptionInput.focus();
                return false;
            }
            
            // Validate category
            const categoryInput = document.querySelector('select[name="category"]');
            if (!categoryInput.value) {
                Swal.fire({
                    title: 'Category Required',
                    text: 'Please select a category',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
                categoryInput.focus();
                return false;
            }
            
            const variantItems = document.querySelectorAll('.variant-item');
            
            for (let item of variantItems) {
                const variantIndex = item.getAttribute('data-variant-index');
                const variantNumber = item.querySelector('h3').textContent.split('#')[1];
                
                // Validate color
                const colorInput = item.querySelector('input[name*="[color]"]');
                const color = colorInput.value.trim();
                
                if (color.length < 2) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `Variant #${variantNumber}: Color must be at least 2 characters`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    colorInput.focus();
                    return false;
                }
                
                // Check for invalid characters (only dashes, underscores, or special chars)
                if (/^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~]+$/.test(color)) {
                    Swal.fire({
                        title: 'Invalid Color',
                        text: `Variant #${variantNumber}: "${color}" is not a valid color name. Please enter a proper color (e.g., Black, White, Red)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    colorInput.focus();
                    return false;
                }
                
                // Validate stock quantity
                const quantityInput = item.querySelector('input[name*="[quantity]"]');
                const quantity = parseInt(quantityInput.value);
                
                if (isNaN(quantity) || quantity < 0) {
                    Swal.fire({
                        title: 'Invalid Stock',
                        text: `Variant #${variantNumber}: Stock quantity must be 0 or greater`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    quantityInput.focus();
                    return false;
                }
                
                const files = croppedFiles[variantIndex] || [];
                
                // Check minimum 3 images required
                if (files.length < 3) {
                    Swal.fire({
                        title: 'Insufficient Images',
                        text: `Variant #${variantNumber} requires minimum 3 images! Currently: ${files.length} image(s)`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                // Check price validation
                const regularPrice = parseFloat(item.querySelector('[data-regular]').value) || 0;
                const salePrice = parseFloat(item.querySelector('[data-sale]').value) || 0;
                
                if (regularPrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant #${variantNumber}: Regular price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                if (salePrice <= 0) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant #${variantNumber}: Sale price must be greater than 0`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
                
                if (salePrice > regularPrice) {
                    Swal.fire({
                        title: 'Invalid Price',
                        text: `Variant #${variantNumber}: Sale price (₹${salePrice}) cannot be greater than regular price (₹${regularPrice})`,
                        icon: 'error',
                        confirmButtonColor: '#1f2937'
                    });
                    return false;
                }
            }
            
            return true;
        }

        // Submit Form
        let isSubmitting = false; // Flag to prevent double submission
        
        function submitForm() {
            // Prevent double submission
            if (isSubmitting) {
                console.log('Form is already being submitted, ignoring duplicate call');
                return;
            }
            
            isSubmitting = true;
            
            const form = document.querySelector('#addProductForm');
            const formData = new FormData(form);
            const submitBtn = document.getElementById('submitBtn');
            
            // Remove old file inputs
            const oldInputs = form.querySelectorAll('.variant-images-input');
            oldInputs.forEach(input => {
                const fieldName = input.getAttribute('name');
                if (fieldName) formData.delete(fieldName);
            });

            // Add cropped images
            for (const variantIndex in croppedFiles) {
                const files = croppedFiles[variantIndex];
                files.forEach(file => {
                    formData.append(`variants[${variantIndex}][images]`, file);
                });
            }

            // Show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';

            // Submit form
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    Swal.fire({
                        title: 'Success!',
                        text: 'Product added successfully!',
                        icon: 'success',
                        confirmButtonColor: '#1f2937'
                    }).then(() => {
                        window.location.href = '/admin/products';
                    });
                } else {
                    throw new Error('Server error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                isSubmitting = false; // Reset flag on error
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                Swal.fire({
                    title: 'Error',
                    text: 'Failed to add product. Please try again.',
                    icon: 'error',
                    confirmButtonColor: '#1f2937'
                });
            });
        }

        // Expose submitForm globally for validation script
        window.submitForm = submitForm;

        // Real-time Validation
        document.addEventListener('DOMContentLoaded', function() {
            // Product Name Validation
            const productNameInput = document.getElementById('productName');
            const productNameError = document.getElementById('productName-error');
            
            productNameInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value.length > 0 && value.length < 3) {
                    this.classList.add('border-red-500');
                    productNameError.textContent = 'Product name must be at least 3 characters';
                    productNameError.classList.remove('hidden');
                } else {
                    this.classList.remove('border-red-500');
                    productNameError.classList.add('hidden');
                }
                updateSubmitButtonState();
            });
            
            // Description Validation
            const descriptionInput = document.getElementById('description');
            const descriptionError = document.getElementById('description-error');
            
            descriptionInput.addEventListener('input', function() {
                const value = this.value.trim();
                if (value.length > 0 && value.length < 10) {
                    this.classList.add('border-red-500');
                    descriptionError.textContent = 'Description must be at least 10 characters';
                    descriptionError.classList.remove('hidden');
                } else {
                    this.classList.remove('border-red-500');
                    descriptionError.classList.add('hidden');
                }
                updateSubmitButtonState();
            });
            
            // Category Validation
            const categoryInput = document.getElementById('category');
            const categoryError = document.getElementById('category-error');
            
            categoryInput.addEventListener('change', function() {
                if (!this.value) {
                    this.classList.add('border-red-500');
                    categoryError.textContent = 'Please select a category';
                    categoryError.classList.remove('hidden');
                } else {
                    this.classList.remove('border-red-500');
                    categoryError.classList.add('hidden');
                }
                updateSubmitButtonState();
            });
        });
        
        // Real-time Price and Color Validation
        document.addEventListener('input', function(e) {
            const variant = e.target.closest('.variant-item');
            if (!variant) return;
            
            // Price validation
            const regularInput = variant.querySelector('[data-regular]');
            const saleInput = variant.querySelector('[data-sale]');
            const priceErrorMsg = variant.querySelector('.price-error');
            
            if (regularInput && saleInput && priceErrorMsg) {
                const regular = parseFloat(regularInput.value) || 0;
                const sale = parseFloat(saleInput.value) || 0;
                
                if (sale > regular && regular > 0) {
                    saleInput.classList.add('border-red-500');
                    priceErrorMsg.textContent = `Sale price cannot exceed ₹${regular}`;
                    priceErrorMsg.classList.remove('hidden');
                } else {
                    saleInput.classList.remove('border-red-500');
                    priceErrorMsg.classList.add('hidden');
                }
            }
            
            // Color validation
            if (e.target.hasAttribute('data-color')) {
                const colorInput = e.target;
                const colorError = variant.querySelector('.color-error');
                const color = colorInput.value.trim();
                
                if (color.length > 0 && color.length < 2) {
                    colorInput.classList.add('border-red-500');
                    colorError.textContent = 'Color must be at least 2 characters';
                    colorError.classList.remove('hidden');
                } else if (color.length >= 2 && /^[-_\s!@#$%^&*()+=\[\]{};:'",.<>?\/\\|`~]+$/.test(color)) {
                    colorInput.classList.add('border-red-500');
                    colorError.textContent = 'Invalid color. Use proper color names (e.g., Black, Red)';
                    colorError.classList.remove('hidden');
                } else {
                    colorInput.classList.remove('border-red-500');
                    colorError.classList.add('hidden');
                }
            }
            
            updateSubmitButtonState();
        });
    </script>
</body>
</html>
